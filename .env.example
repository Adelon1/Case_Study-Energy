# Copy this file to .env and fill in the real values locally.

# ENTSO-E Transparency Platform REST API security token.
# How to request access:
# 1. Register on https://transparency.entsoe.eu/
# 2. Follow the official guide:
#    https://transparencyplatform.zendesk.com/hc/en-us/articles/12845911031188-How-to-get-security-token
# 3. After access is granted, generate/copy the token into .env
ENTSOE_API_KEY=your_entsoe_security_token_here

# OpenAI API key for the optional AI commentary workflow.
# How to create it:
# 1. Sign in at https://platform.openai.com/
# 2. Open the API keys page from the dashboard/project settings.
# 3. Create a new secret key and copy it here in your local .env file.
# 4. Never commit the real key.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini
