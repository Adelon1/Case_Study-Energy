# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments
.venv/
venv/
env/

# Local secrets and environment files
.env
.env.*
!.env.example

# Jupyter/runtime files
.ipynb_checkpoints/
*.log

# OS/editor noise
.DS_Store
Thumbs.db
.vscode/
.idea/

# Generated data and outputs
data/raw/**
data/interim/**
data/processed/**
outputs/**
report/*.pdf

# Keep directory placeholders if added later
!.gitkeep
!data/raw/
!data/raw/entsoe/
!data/raw/energy_charts/
!data/raw/entsoe/.gitkeep
!data/raw/energy_charts/.gitkeep
!data/interim/
!data/interim/.gitkeep
!data/processed/
!data/processed/.gitkeep
